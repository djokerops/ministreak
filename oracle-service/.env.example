# Oracle hot wallet private key (with 0x prefix)
ORACLE_PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# Celo RPC endpoint (Celo Sepolia for testnet, mainnet for prod)
CELO_RPC_URL=https://forno.celo-sepolia.celo-testnet.org

# Deployed contract addresses (fill after npm run deploy:sepolia in contracts/)
VAULT_ADDRESS=0x0000000000000000000000000000000000000000
ORACLE_ADDRESS=0x0000000000000000000000000000000000000000

# USDT token address
# On Celo Sepolia: MockUSDT address from deploy:sepolia output
# On Mainnet: verify official USDT address before use
USDT_ADDRESS=0x0000000000000000000000000000000000000000

# Minimum qualifying volume in USDT (default: 0.5)
MIN_VOLUME_USDT=0.5

# SQLite database path for tracking submitted streaks
DB_PATH=./oracle.db

# Webhook URL for low-balance alerts (optional, e.g. Slack webhook)
WEBHOOK_ALERT_URL=https://hooks.slack.com/services/your/webhook/url

# Minimum oracle wallet CELO balance before alerting (in CELO)
MIN_CELO_BALANCE=0.1

# How many blocks to look back when scanning (720 ≈ 1 hour on Celo Sepolia)
BLOCKS_LOOKBACK=720

# Cron schedule for the oracle run (default: every hour)
CRON_SCHEDULE=0 * * * *

# Log level: debug | info | warn | error
LOG_LEVEL=info
