# Chain ID — 11142220=Celo Sepolia (testnet), 42220=Celo Mainnet, 31337=localhost
NEXT_PUBLIC_CHAIN_ID=11142220

# Celo RPC URL — leave blank to use default for the chosen chain
NEXT_PUBLIC_CELO_RPC_URL=https://forno.celo-sepolia.celo-testnet.org

# Deployed contract addresses (fill after npm run deploy:sepolia)
NEXT_PUBLIC_VAULT_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_ORACLE_ADDRESS=0x0000000000000000000000000000000000000000

# USDT token address
# On Celo Sepolia: the MockUSDT address printed by deploy:sepolia
# On Celo Mainnet: verify official USDT address before use
NEXT_PUBLIC_USDT_ADDRESS=0x0000000000000000000000000000000000000000

# The Graph subgraph API URL (optional — leave blank to fall back to on-chain reads)
NEXT_PUBLIC_GRAPH_API_URL=https://api.studio.thegraph.com/query/YOUR_ID/celo-grind/version/latest

# WalletConnect project ID (for non-MiniPay browser fallback — get one at cloud.walletconnect.com)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id

# Charity address for "Make today's tx" shortcut (must not equal deployer — avoids self-send)
NEXT_PUBLIC_CHARITY_ADDRESS=0x4C6Aa14F58aFb01CB0515aD33e03Ec16a67f4E55
